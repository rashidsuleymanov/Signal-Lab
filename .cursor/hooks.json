{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/check-shell-safety.js",
        "timeout": 10,
        "failClosed": true
      },
      {
        "command": "node .cursor/hooks/ensure-env-for-compose.js",
        "timeout": 10,
        "matcher": "docker\\s+compose\\s+up",
        "failClosed": false
      }
    ]
  }
}
