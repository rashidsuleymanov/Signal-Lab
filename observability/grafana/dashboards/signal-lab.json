{
  "uid": "signal-lab",
  "title": "Signal Lab — Scenarios",
  "timezone": "browser",
  "schemaVersion": 40,
  "version": 1,
  "refresh": "5s",
  "tags": ["signal-lab"],
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Scenario Runs by Type (rate)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (type) (rate(scenario_runs_total[1m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Latency p95 (seconds)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, type) (rate(scenario_run_duration_seconds_bucket[5m])))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "showLegend": true, "placement": "bottom" } }
    },
    {
      "type": "timeseries",
      "title": "Error Rate (non-completed)",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(scenario_runs_total{status!=\"completed\"}[5m]))",
          "legendFormat": "errors"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },
    {
      "type": "logs",
      "title": "Recent logs (Loki)",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "datasource": "Loki",
      "targets": [
        {
          "expr": "{app=\"signal-lab\"}",
          "refId": "A"
        }
      ],
      "options": { "showLabels": true, "wrapLogMessage": true }
    }
  ]
}
